{
  "name": "cursor-crew",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Vibe Jam 2026 entry — a 120s top-down arena game where you pick a system cursor and fight waves of hostile UI elements.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "party:dev": "partykit dev",
    "worker:deploy": "cd worker && wrangler deploy"
  },
  "devDependencies": {
    "partykit": "^0.0.115",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
