{
  "name": "cursor-crew-bug-detective",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Bug Detective — Vibe Jam 2026 single-case 3D detective puzzle.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "verify": "npm test && npm run e2e && npm run build && bash scripts/check-jam-widget.sh",
    "worker:deploy": "cd worker && wrangler deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/three": "^0.184.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
